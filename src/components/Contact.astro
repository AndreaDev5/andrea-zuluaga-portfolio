---
import { site } from '../data/site';
import Reveal from './Reveal.tsx';
import Icon from './Icon.astro';

const channels = [
  { name: 'Email', value: site.email, href: `mailto:${site.email}`, icon: 'mail' },
  { name: 'LinkedIn', value: 'in/andrea-zuluaga-monroy', href: site.linkedin, icon: 'linkedin' },
  { name: 'GitHub', value: '@AndreaDev5', href: site.github, icon: 'github' },
];
---
<section id="contact" class="border-t border-border py-20 sm:py-28">
  <div class="container-page grid gap-12 lg:grid-cols-12">
    <div class="lg:col-span-5">
      <Reveal client:visible>
        <span class="eyebrow mb-4">Contacto</span>
        <h2 class="section-title">Hablemos</h2>
        <p class="mt-4 max-w-md text-muted">
          ¿Tienes un proyecto de datos, automatización o IA en mente? Escríbeme y conversemos.
        </p>

        <ul class="mt-8 space-y-3">
          {channels.map((c) => (
            <li>
              <a
                href={c.href}
                target={c.icon === 'mail' ? undefined : '_blank'}
                rel="noopener noreferrer"
                class="card-surface flex items-center gap-4 p-4 hover:-translate-y-0.5 hover:border-accent/60"
              >
                <span class="grid h-10 w-10 shrink-0 place-items-center rounded-xl bg-accent-soft text-accent">
                  <Icon name={c.icon} size={18} />
                </span>
                <span class="min-w-0">
                  <span class="block text-sm font-medium text-ink">{c.name}</span>
                  <span class="block truncate text-sm text-muted">{c.value}</span>
                </span>
              </a>
            </li>
          ))}
        </ul>
      </Reveal>
    </div>

    <div class="lg:col-span-7 lg:mt-12">
      <Reveal client:visible delay={0.1}>
        <form id="contact-form" class="card-surface p-6 sm:p-8">
          <div class="grid gap-5 sm:grid-cols-2">
            <div class="sm:col-span-1">
              <label for="name" class="mb-2 block text-sm font-medium text-ink">Nombre</label>
              <input
                id="name" name="name" type="text" required
                class="w-full rounded-xl border border-border bg-bg px-4 py-3 text-sm text-ink placeholder:text-muted/70 focus:border-accent"
                placeholder="Tu nombre"
              />
            </div>
            <div class="sm:col-span-1">
              <label for="email" class="mb-2 block text-sm font-medium text-ink">Email</label>
              <input
                id="email" name="email" type="email" required
                class="w-full rounded-xl border border-border bg-bg px-4 py-3 text-sm text-ink placeholder:text-muted/70 focus:border-accent"
                placeholder="tu@email.com"
              />
            </div>
          </div>
          <div class="mt-5">
            <label for="message" class="mb-2 block text-sm font-medium text-ink">Mensaje</label>
            <textarea
              id="message" name="message" rows="5" required
              class="w-full resize-y rounded-xl border border-border bg-bg px-4 py-3 text-sm text-ink placeholder:text-muted/70 focus:border-accent"
              placeholder="Cuéntame sobre tu proyecto…"
            ></textarea>
          </div>
          <div class="mt-6 flex items-center justify-between gap-4">
            <button type="submit" class="btn-primary">
              Enviar mensaje
              <Icon name="arrow-right" size={18} />
            </button>
            <p id="form-status" class="text-sm text-muted" aria-live="polite"></p>
          </div>
        </form>
      </Reveal>
    </div>
  </div>
</section>

<script is:inline define:vars={{ email: site.email }}>
  // Sin backend: abre el cliente de correo con el mensaje prellenado (mailto).
  // Para envío directo, swap a Formspree: action="https://formspree.io/f/XXXX" method="POST".
  const form = document.getElementById('contact-form');
  const status = document.getElementById('form-status');
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const data = new FormData(form);
    const name = (data.get('name') || '').toString();
    const from = (data.get('email') || '').toString();
    const message = (data.get('message') || '').toString();
    const subject = encodeURIComponent(`Contacto portafolio — ${name}`);
    const body = encodeURIComponent(`${message}\n\n—\n${name} (${from})`);
    status.textContent = 'Abriendo tu correo…';
    window.location.href = `mailto:${email}?subject=${subject}&body=${body}`;
  });
</script>
