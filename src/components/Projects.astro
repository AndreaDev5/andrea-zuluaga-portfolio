---
import { projects } from '../data/projects';
import Reveal from './Reveal.tsx';
import Icon from './Icon.astro';
---
<section id="projects" class="border-t border-border bg-surface py-20 sm:py-28">
  <div class="container-page">
    <Reveal client:visible>
      <div class="max-w-2xl">
        <span class="eyebrow mb-4">Proyectos</span>
        <p class="mt-4 text-muted">
          Soluciones de datos, automatización e IA aplicadas a problemas reales de operación.
        </p>
      </div>
    </Reveal>

    <div class="mt-12 grid gap-5 sm:grid-cols-2">
      {projects.map((project, i) => (
        <Reveal client:visible delay={(i % 2) * 0.08}>
          <article class="card-surface group flex h-full flex-col p-6 hover:-translate-y-1 hover:border-accent/60 hover:shadow-glow">
            <div class="flex items-center gap-3">
              <span class="grid h-10 w-10 shrink-0 place-items-center rounded-xl border border-border bg-bg text-xs font-bold text-gradient">
                {project.accent}
              </span>
              <h3 class="text-base font-semibold text-ink">{project.title}</h3>
            </div>

            <p class="mt-4 flex-1 text-sm leading-relaxed text-muted">
              {project.description}
            </p>

            <ul class="mt-4 flex flex-wrap gap-2">
              {project.tags.map((tag) => (
                <li class="rounded-lg border border-border bg-bg px-2.5 py-1 text-xs font-medium text-muted">
                  {tag}
                </li>
              ))}
            </ul>

            {(project.github || project.demo) && (
              <div class="mt-5 flex items-center gap-4 border-t border-border pt-4">
                {project.github && (
                  <a
                    href={project.github}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center gap-1.5 text-sm link-muted"
                  >
                    <Icon name="github" size={16} /> Código
                  </a>
                )}
                {project.demo && (
                  <a
                    href={project.demo}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center gap-1.5 text-sm link-muted"
                  >
                    <Icon name="arrow-up-right" size={16} /> Demo
                  </a>
                )}
              </div>
            )}
          </article>
        </Reveal>
      ))}
    </div>
  </div>
</section>
