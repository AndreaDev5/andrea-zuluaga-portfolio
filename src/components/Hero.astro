---
import { Image } from 'astro:assets';
import andrea from '../assets/andrea.jpg';
import { site } from '../data/site';
import Icon from './Icon.astro';
import Reveal from './Reveal.tsx';
---
<section id="home" class="relative overflow-hidden pt-32 pb-20 sm:pt-40 sm:pb-28">
  <!-- Fondo minimalista: solo grid sutil (el glow va únicamente en el círculo de la foto) -->
  <div class="pointer-events-none absolute inset-0 -z-10">
    <div class="absolute inset-0 grid-mask"></div>
  </div>

  <div class="container-page flex flex-col items-center text-center">
    <Reveal client:load>
      <div class="relative mx-auto mb-8 h-44 w-44 sm:h-52 sm:w-52">
        <div class="glow-blob absolute inset-0 scale-110"></div>
        <div class="relative h-full w-full overflow-hidden rounded-full border border-border shadow-glow">
          <Image
            src={andrea}
            alt="Andrea Zuluaga"
            width={416}
            height={416}
            class="h-full w-full object-cover object-center"
            loading="eager"
          />
        </div>
      </div>
    </Reveal>

    <Reveal client:load delay={0.1}>
      <span class="eyebrow mb-5">
        <span class="h-1.5 w-1.5 rounded-full bg-accent"></span>
        Disponible para nuevos retos
      </span>
    </Reveal>

    <Reveal client:load delay={0.15}>
      <h1 class="mx-auto max-w-3xl text-4xl font-semibold tracking-tight text-ink sm:text-6xl">
        Andrea Zuluaga
      </h1>
    </Reveal>

    <Reveal client:load delay={0.22}>
      <p class="mt-4 text-base font-medium text-muted sm:text-lg">
        Data Analyst · <span class="text-gradient">Process Automation</span> · FinOps
      </p>
    </Reveal>

    <Reveal client:load delay={0.3}>
      <p class="mx-auto mt-6 max-w-2xl text-base leading-relaxed text-muted sm:text-lg">
        {site.tagline}
      </p>
    </Reveal>

    <Reveal client:load delay={0.4}>
      <div class="mt-9 flex flex-wrap items-center justify-center gap-3">
        <a href="#projects" class="btn-primary">
          Ver Proyectos
          <Icon name="arrow-right" size={18} />
        </a>
        <a href="#contact" class="btn-ghost">
          Contacto
          <Icon name="mail" size={18} />
        </a>
      </div>
    </Reveal>
  </div>
</section>
