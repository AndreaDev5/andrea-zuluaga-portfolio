---
import { skills } from '../data/skills';
import Reveal from './Reveal.tsx';
import Icon from './Icon.astro';
---
<section id="skills" class="border-t border-border bg-surface py-20 sm:py-28">
  <div class="container-page">
    <Reveal client:visible>
      <span class="eyebrow">Skills</span>
    </Reveal>

    <div class="mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
      {skills.map((group, i) => (
        <Reveal client:visible delay={i * 0.08}>
          <div class="card-surface group h-full p-5 hover:-translate-y-1 hover:border-accent/60 hover:shadow-glow">
            <span class="grid h-10 w-10 place-items-center rounded-xl bg-accent-soft text-accent transition-transform group-hover:scale-105">
              <Icon name={group.icon} size={20} />
            </span>
            <h3 class="mt-4 text-base font-semibold text-ink">{group.title}</h3>
            <ul class="mt-3 flex flex-wrap gap-2">
              {group.items.map((item) => (
                <li class="rounded-lg border border-border bg-bg px-2.5 py-1 text-xs font-medium text-muted">
                  {item}
                </li>
              ))}
            </ul>
          </div>
        </Reveal>
      ))}
    </div>
  </div>
</section>
